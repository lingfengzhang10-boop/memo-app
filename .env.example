# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Provider
AI_API_KEY=your_model_provider_api_key_here
AI_BASE_URL=https://api.siliconflow.cn/v1

# Core ASR + analysis
AI_TRANSCRIBE_MODEL=FunAudioLLM/SenseVoiceSmall
AI_ANALYSIS_MODEL=Pro/zai-org/GLM-4.7

# Generic companion speech
AI_TTS_MODEL=fnlp/MOSS-TTSD-v0.5
AI_TTS_VOICE=fnlp/MOSS-TTSD-v0.5:claire
AI_TTS_FORMAT=mp3
AI_TTS_SPEED=0.96
AI_TTS_STYLE_PROMPT=请用温柔、自然、陪伴式的中文口语来读下面这段话，语速稍慢，带一点停顿，不要播音腔。
AI_TTS_TIMEOUT_MS=18000

# Twin voice clone + twin speech
AI_TWIN_VOICE_CLONE_MODEL=FunAudioLLM/CosyVoice2-0.5B
AI_TWIN_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
AI_TWIN_TTS_FORMAT=mp3
AI_TWIN_TTS_SPEED=0.96
AI_TWIN_TTS_STYLE_PROMPT=请用自然、像真人陪伴聊天一样的中文口语读下面这段话，语速稍慢，带一点停顿，不要播音腔，也不要夸张演绎。
AI_TWIN_TTS_TIMEOUT_MS=20000
AI_TWIN_DEFAULT_VOICE=FunAudioLLM/CosyVoice2-0.5B:claire

# Frontend toggles
NEXT_PUBLIC_ENABLE_LOCAL_ASR=false
NEXT_PUBLIC_LOCAL_ASR_MODEL=Xenova/whisper-tiny
NEXT_PUBLIC_ENABLE_SERVER_TTS=false

# Example
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
